rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated (including anonymous sign-in)
    function isSignedIn() {
      return request.auth != null;
    }

    // Assessments rules (Patient Screenings)
    match /assessments/{assessmentId} {
      allow read, create: if isSignedIn();
      // Allow updates to change status or assign CHW
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Notifications rules (CHW Alert system)
    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    // CHW Profile registry rules
    match /chws/{chwId} {
      allow read, write: if isSignedIn();
    }

    // Recovery Logs rules
    match /recovery_logs/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}
