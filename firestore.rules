rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /assessments/{assessmentId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.riskLevel in ['Low', 'Moderate', 'High']
        && request.resource.data.riskScore is number;
      allow update: if false; // Assessments are immutable records
      allow delete: if isOwner(resource.data.userId);
    }

    match /recovery_logs/{logId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.mood >= 1 && request.resource.data.mood <= 5;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
